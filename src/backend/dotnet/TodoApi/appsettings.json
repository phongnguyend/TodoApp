{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=todo.db"
  },
  "FileStorage": {
    "Path": "uploads",
    "MaxUploadSizeBytes": 10485760
  },
  "PasswordReset": {
    "TokenLifetimeMinutes": 60,
    "ConfirmationUrl": "/reset-password"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
