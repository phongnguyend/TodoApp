APP_NAME="Todo API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite (default - for development)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

# MySQL example:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=todo_db
# DB_USERNAME=root
# DB_PASSWORD=

# PostgreSQL example:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=todo_db
# DB_USERNAME=postgres
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database

QUEUE_CONNECTION=sync

# Pagination defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# User authentication and password resets
# Shared HMAC secret used to validate HS256 bearer tokens on profile/password routes.
JWT_SECRET_KEY=change-this-in-production
PASSWORD_RESET_TOKEN_LIFETIME_MINUTES=60
PASSWORD_RESET_CONFIRMATION_URL=http://localhost:3000/reset-password

# File uploads
# FILE_STORAGE_PATH=/absolute/path/to/storage/app/uploads
MAX_UPLOAD_SIZE_BYTES=10485760

# L5-Swagger
L5_SWAGGER_GENERATE_ALWAYS=true

# SMTP - used by the background worker to send incomplete-item reminders
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Address that receives the incomplete-todo reminder emails
MAIL_REMINDER_RECIPIENT="admin@example.com"
