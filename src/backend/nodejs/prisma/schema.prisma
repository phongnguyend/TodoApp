// Prisma schema - analogous to EF Core entity configuration + DbContext
// Run: npx prisma migrate dev --name InitialCreate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"           // swap to "postgresql" or "mysql" for production
  url      = env("DATABASE_URL")
}

model TodoItem {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  attachments TodoItemAttachment[]

  @@map("todo_items")
}

model EmailLog {
  id           Int       @id @default(autoincrement())
  recipient    String
  subject      String
  body         String
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  sentAt       DateTime?
  errorMessage String?

  @@map("email_logs")
}

model File {
  id          Int       @id @default(autoincrement())
  name        String
  extension   String
  size        Int
  contentType String?
  location    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  attachments TodoItemAttachment[]

  @@map("files")
}

model TodoItemAttachment {
  id         Int       @id @default(autoincrement())
  todoItemId Int
  fileId     Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime? @updatedAt
  todoItem   TodoItem  @relation(fields: [todoItemId], references: [id], onDelete: Cascade)
  file       File      @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([todoItemId, fileId])
  @@index([fileId])
  @@map("todo_item_attachments")
}
