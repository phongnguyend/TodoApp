// Prisma schema - analogous to EF Core entity configuration + DbContext
// Run: npx prisma migrate dev --name InitialCreate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"           // swap to "postgresql" or "mysql" for production
  url      = env("DATABASE_URL")
}

model TodoItem {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  createdByUserId Int?
  updatedAt   DateTime? @updatedAt
  updatedByUserId Int?
  attachments TodoItemAttachment[]
  createdByUser User? @relation("TodoItemCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("TodoItemUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("todo_items")
}

model EmailLog {
  id           Int       @id @default(autoincrement())
  recipient    String
  subject      String
  body         String
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  createdByUserId Int?
  sentAt       DateTime?
  errorMessage String?
  updatedByUserId Int?
  createdByUser User? @relation("EmailLogCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("EmailLogUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("email_logs")
}

model File {
  id          Int       @id @default(autoincrement())
  name        String
  extension   String
  size        Int
  contentType String?
  location    String
  createdAt   DateTime  @default(now())
  createdByUserId Int?
  updatedAt   DateTime? @updatedAt
  updatedByUserId Int?
  attachments TodoItemAttachment[]
  createdByUser User? @relation("FileCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("FileUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("files")
}

model TodoItemAttachment {
  id         Int       @id @default(autoincrement())
  todoItemId Int
  fileId     Int
  createdAt  DateTime  @default(now())
  createdByUserId Int?
  updatedAt  DateTime? @updatedAt
  updatedByUserId Int?
  todoItem   TodoItem  @relation(fields: [todoItemId], references: [id], onDelete: Cascade)
  file       File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("AttachmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("AttachmentUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([todoItemId, fileId])
  @@index([fileId])
  @@map("todo_item_attachments")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  passwordHash String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  createdByUserId Int?
  updatedAt    DateTime? @updatedAt
  updatedByUserId Int?
  createdByUser User? @relation("UserCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("UserUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  usersCreated User[] @relation("UserCreatedBy")
  usersUpdated User[] @relation("UserUpdatedBy")
  todoItemsCreated TodoItem[] @relation("TodoItemCreatedBy")
  todoItemsUpdated TodoItem[] @relation("TodoItemUpdatedBy")
  attachmentsCreated TodoItemAttachment[] @relation("AttachmentCreatedBy")
  attachmentsUpdated TodoItemAttachment[] @relation("AttachmentUpdatedBy")
  filesCreated File[] @relation("FileCreatedBy")
  filesUpdated File[] @relation("FileUpdatedBy")
  emailLogsCreated EmailLog[] @relation("EmailLogCreatedBy")
  emailLogsUpdated EmailLog[] @relation("EmailLogUpdatedBy")

  @@map("users")
}
