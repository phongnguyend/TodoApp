# Application
PORT=3000

# Database connection string
# SQLite (default — for development)
DATABASE_URL="file:./todo.db"

# PostgreSQL example:
# DATABASE_URL="postgresql://user:password@localhost:5432/todo_db?schema=public"

# MySQL example:
# DATABASE_URL="mysql://user:password@localhost:3306/todo_db"

# ── SMTP (used by the background worker) ──────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
# true  → SMTP_SSL (port 465); false → plain SMTP + STARTTLS (port 587)
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_SENDER=noreply@example.com
EMAIL_RECIPIENT=admin@example.com

# ── Background worker ─────────────────────────────────────────────────────────
WORKER_INTERVAL_MINUTES=60
