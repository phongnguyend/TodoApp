# Application
APP_NAME=Todo API
APP_VERSION=1.0.0
DEBUG=false

# Database connection string
# SQLite (default — for development)
DATABASE_URL=sqlite:///./todo.db

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/todo_db

# MySQL example:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/todo_db

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
