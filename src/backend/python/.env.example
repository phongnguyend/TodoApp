# Application
APP_NAME=Todo API
APP_VERSION=1.0.0
DEBUG=false

# Database connection string
# SQLite (default - for development)
DATABASE_URL=sqlite:///./todo.db

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/todo_db

# MySQL example:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/todo_db

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── SMTP (required by the background worker) ──────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# true  → plain SMTP + STARTTLS (port 587)
# false → SMTP_SSL           (port 465)
SMTP_USE_TLS=true
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=changeme
EMAIL_SENDER=noreply@example.com
EMAIL_RECIPIENT=admin@example.com

# ── File uploads ────────────────────────────────────────────────────────────
FILE_STORAGE_PATH=./uploads
MAX_UPLOAD_SIZE_BYTES=10485760

# ── Background worker ─────────────────────────────────────────────────────────
# How often (in minutes) the worker sends the incomplete-todos digest
WORKER_INTERVAL_MINUTES=60
