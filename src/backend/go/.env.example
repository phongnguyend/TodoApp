# Application
APP_NAME=Todo API
APP_VERSION=1.0.0
PORT=8080

# Database connection string
# SQLite (default - for development)
DATABASE_DSN=todo.db

# PostgreSQL example (swap driver import in database.go):
# DATABASE_DSN=host=localhost user=postgres password=secret dbname=todo_db port=5432 sslmode=disable

# MySQL example:
# DATABASE_DSN=user:password@tcp(localhost:3306)/todo_db?charset=utf8mb4&parseTime=True

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Authentication and password reset
JWT_SECRET_KEY=change-me-use-at-least-32-bytes-long
JWT_TOKEN_LIFETIME_MINUTES=60
PASSWORD_HASH_ITERATIONS=120000
PASSWORD_RESET_SECRET_KEY=change-me-too
PASSWORD_RESET_TOKEN_LIFETIME_MINUTES=60
PASSWORD_RESET_CONFIRMATION_URL=/reset-password

# ── File uploads ───────────────────────────────────────────────────────────────
# Directory where uploaded file content is stored
FILE_STORAGE_PATH=./uploads
# Maximum accepted upload size, in bytes (default 10 MB)
MAX_UPLOAD_SIZE_BYTES=10485760

# ── Background worker ─────────────────────────────────────────────────────────
# How often the worker runs the incomplete-todos email digest (in minutes)
WORKER_INTERVAL_MINUTES=60

# SMTP settings
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Set to true for STARTTLS (port 587), false for plain SMTP (port 25) or SSL (port 465)
SMTP_USE_TLS=true

# Email addresses
EMAIL_SENDER=noreply@example.com
EMAIL_RECIPIENT=admin@example.com
