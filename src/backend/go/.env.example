# Application
APP_NAME=Todo API
APP_VERSION=1.0.0
PORT=8080

# Database connection string
# SQLite (default — for development)
DATABASE_DSN=todo.db

# PostgreSQL example (swap driver import in database.go):
# DATABASE_DSN=host=localhost user=postgres password=secret dbname=todo_db port=5432 sslmode=disable

# MySQL example:
# DATABASE_DSN=user:password@tcp(localhost:3306)/todo_db?charset=utf8mb4&parseTime=True

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
